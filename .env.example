# === SERVER ===
PORT=5000
NODE_ENV=production

# === API UPSTREAM ===
# TransityTerminal instance URL — digunakan untuk endpoint /api/app/* (auth, profile, booking list)
API_UPSTREAM=https://nusa-terminal.transity.web.id

# === CONSOLE URL ===
# TransityConsole gateway URL — digunakan untuk endpoint /api/gateway/* (trips, seatmap, bookings)
# Jika tidak diset, akan fallback ke API_UPSTREAM
CONSOLE_URL=https://your-transity-console-domain.com
